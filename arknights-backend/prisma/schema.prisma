generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  uid       String   @id
  updatedAt DateTime @updatedAt
  stats     UserBannerStat[]
}

// Храним ТОЛЬКО итоговые цифры для рейтинга
model UserBannerStat {
  uid        String
  bannerId   String // 'standard', 'special', 'special_banner_01' и т.д.
  
  // Общие
  totalPulls Int @default(0)
  lastUpdate DateTime @default(now())

  // Удача (6 звезд)
  total6     Int @default(0)
  sumPity6   Int @default(0) // Сумма пити всех 6* (для расчета среднего: sumPity6 / total6)
  
  // Удача (5 звезд)
  total5     Int @default(0)
  sumPity5   Int @default(0)

  // 50 на 50
  won5050    Int @default(0) // Сколько раз выиграл
  total5050  Int @default(0) // Сколько раз был шанс 50/50 (выпал 6*, когда не было гаранта)

  user       User @relation(fields: [uid], references: [uid])

  // Составной ключ: у юзера может быть только 1 статистика для конкретного баннера
  @@id([uid, bannerId])
  
  // Индексы для быстрого построения топов
  @@index([bannerId, totalPulls]) 
  @@index([bannerId, sumPity6])
}